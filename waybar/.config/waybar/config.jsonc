[{

  "layer": "top",
  "position": "top",
  "mod": "dock",
  "height": 10,
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,


	"modules-left": [
    "custom/ll_end",
    "hyprland/workspaces",
    "hyprland/window",
    "custom/r_end",
    "custom/l_end",
    "cpu",
    "memory",
    "temperature",
    "custom/rr_end"
  ],

	"modules-center": [
    "custom/ll_end",
    "custom/spotify",
    "mpd",
    "custom/rr_end"
  ],

	"modules-right": [
    "custom/ll_end",
    "clock",
    "custom/r_end",
    "custom/l_end",
    "battery",
    "pulseaudio",
    "pulseaudio#microphone",
    "custom/updates",
    "custom/r_end",
    "custom/l_end",
    "tray",
    "custom/rr_end"
  ],

  "cpu": {
    "interval": 10,
    "format": "َ°چ›  {usage}%",
    "format-alt": "{icon0}{icon1}{icon2}{icon3}",
    "format-icons": ["â–پ", "â–‚", "â–ƒ", "â–„", "â–…", "â–†", "â–‡", "â–ˆ"]
  },

  "memory": {
    "interval": 30,
    "format": "َ°¾†  {percentage}%",
    "format-alt": "َ°¾…  {used}GB",
    "max-length": 30,
    "tooltip": true,
    "tooltip-format": "î‰¦  {used:0.1f}GB/{total:0.1f}GB"
  },

  "temperature": {
     "format": "ï‹‰  {temperatureC}آ°C"
  },

  "clock": {
    "interval": 60,
    "format": "ïگ؛  {:%I:%M  َ°ƒ­  %a %d}",
    "format-alt": "َ°¥”  {:%H:%M  ï„³  %b %Y}",
    "tooltip-format": "<tt><big>{calendar}</big></tt>"
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "on-click": "activate"
  },

  "hyprland/window": {
    "format": " ïŒƒ {}",
    "max-length": 30,
    "separate-outputs": true,
    "rewrite": {
      "(.*)~(.*)": "ï’‰",
      "(.*) â€” Mozilla Firefox": "َ°ˆ¹  $1",
      "(.*)Mozilla Firefox": "َ°ˆ¹  Firefox",
      "(.*)sb -(.*)": "َ°ˆ¹  Firefox",
      "(.*) - Brave": "َ°ڈڑ  $1",
      "(.*)Brave": "َ°ڈڑ  Brave",
      "(.*) â€” Dolphin": "َ°‰‹  $1",
      "(.*)Spotify": "َ°“‡  Spotify",
      "(.*)Zathura": "َ°ˆ¦  Zathura",
      "(.*)vim(.*)": "îڑ®  Vimming"
    }
  },

  "custom/spotify": {
    "format": "َ°“‡  {}",
    "interval": 5,
    "max-length": 30,
    "on-click": "playerctl play-pause -p spotify",
    "on-click-right": "playerctl next -p spotify",
    "on-click-middle": "playerctl previous -p spotify",
    "on-scroll-up": "playerctl volume 0.1+ -p spotify",
    "on-scroll-down": "playerctl volume 0.1- -p spotify",
    "exec": "playerctl metadata --format \"{{title}} - {{artist}}\" -p spotify"
  },

  "mpd": {
    "server": "/home/comodino/.config/mpd/socket",
    "format": "ï€پ {artist} - {album} - {title} {stateIcon}",
    "format-disconnected": "Disconnected ï€پ",
    "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ï€پ",
    "unknown-tag": "N/A",
    "interval": 5,
    "consume-icons": {
      "on": "ïƒ„ "
    },
    "random-icons": {
      "off": "<span color=\"#f53c3c\">ïپ´</span> ",
      "on": "ïپ´ "
    },
    "repeat-icons": {
      "on": "ï€‍ "
    },
    "single-icons": {
      "on": "ï€‍1 "
    },
    "state-icons": {
      "paused": "ïپŒ",
      "playing": "ïپ‹"
    },
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
  },

  // "custom/mpd": {
  //   "format": "î°›  {}",
  //   "interval": 1,
  //   "max-length": 30,
  //   "on-click": "playerctl play-pause -p mpd.como-music",
  //   "on-click-right": "playerctl next -p mpd.como-music",
  //   "on-click-middle": "playerctl previous -p mpd.como-music",
  //   "on-scroll-up": "playerctl volume 0.1+ -p mpd.como-music",
  //   "on-scroll-down": "playerctl volume 0.1- -p mpd.como-music",
  //   "exec": "playerctl metadata --format \"{{title}} - {{artist}}\" -p mpd.como-music"
  // },

  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 20
    },
    "format": "{icon} {time}",
    "format-alt": "{icon} {capacity}%",
    "format-charging": "ï‡¦ {capacity}%",
    "format-plugged": "ï‡¦ {capacity}%",
    "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
  },

  "pulseaudio": {
    "format": "{icon} {volume}",
    "format-muted": "ïھ€",
    "on-click": "pavucontrol -t 3",
    "on-click-middle": "~/.config/hypr/scripts/volumecontrol.sh -o m",
    "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh -o i",
    "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh -o d",
    "tooltip-format": "{icon} {desc} // {volume}%",
    "scroll-step": 5,
    "format-icons": {
      "headphone": "ï€¥ ",
      "hands-free": "ï€¥ ",
      "headset": "ï€¥ ",
      "phone": "ï‚• ",
      "portable": "ï‚• ",
      "car": "ï†¹ ",
      "default": ["ï€¦ ", "ï€§ ", "ï€¨ "]
    }
  },

  "pulseaudio#microphone": {
    "format": "{format_source}",
    "format-source": "ï،«",
    "format-source-muted": "ï„±",
    "on-click": "pavucontrol -t 4",
    "on-click-middle": "~/.config/hypr/scripts/volumecontrol.sh -i m",
    "on-scroll-up": "~/.config/hypr/scripts/volumecontrol.sh -i i",
    "on-scroll-down": "~/.config/hypr/scripts/volumecontrol.sh -i d",
    "tooltip-format": "{format_source} {source_desc} // {source_volume}%",
    "scroll-step": 5
  },

  "tray": {
    "icon-size": 14,
    "spacing": 10
  },

// modules for padding //

  "custom/l_end": {
    "format": " ",
    "interval" : "once",
    "tooltip": false
  },

  "custom/r_end": {
    "format": " ",
    "interval" : "once",
    "tooltip": false
  },

  "custom/ll_end": {
    "format": " ",
    "interval" : "once",
    "tooltip": false
  },

  "custom/sr_end": {
    "format": " ",
    "interval" : "once",
    "tooltip": false
  },

  "custom/rl_end": {
    "format": " ",
    "interval" : "once",
    "tooltip": false
  },

  "custom/rr_end": {
    "format": " ",
    "interval" : "once",
    "tooltip": false
  }

},

{

  "layer": "bottom",
  "position": "bottom",
  "mod": "dock",
  "height": 10,
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,


	"modules-left": [
    "custom/ll_end",
    "disk#root",
    "custom/r_end",
    "custom/l_end",
    "disk#home",
    "custom/rr_end"
  ],

	"modules-center": [
    "custom/ll_end",
    "custom/player",
    "custom/rr_end"
  ],

	"modules-right": [
    "custom/ll_end",
    "network#wlan",
    "network#eth",
    "custom/rr_end"
  ],

  "disk#root": {
    "interval": 30,
    "path": "/",
    "format": "/: {used}/{total}"
  },

  "disk#home": {
    "interval": 30,
    "path": "/home",
    "format": "/home: {used}/{total}"
  },

  "custom/player": {
    "format": "َ°ڈڑ {}",
    "interval": 1,
    "max-length": 60,
    "on-click": "playerctl play-pause -p brave",
    "on-click-right": "playerctl next -p brave",
    "on-click-middle": "playerctl previous -p brave",
    "on-scroll-up": "playerctl volume 0.1+ -p brave",
    "on-scroll-down": "playerctl volume 0.1- -p brave",
    "exec": "playerctl metadata --format \"{{title}} - {{artist}}\" -p brave"
  },

  "network#wlan": {
    "interface": "wlan0",
    "max-length": 30,
    "format-wifi": "{bandwidthUpBytes} îھ· îھ´ {bandwidthDownBytes}",
    "tooltip": true,
    "tooltip-format": "{ifname}"
  },
  
  "network#eth": {
    "interface": "eth0",
    "max-length": 30,
    "format-ethernet": "{bandwidthUpBytes} îھ· îھ´ {bandwidthDownBytes}",
    "tooltip": true,
    "tooltip-format": "{ifname}"
  },

// modules for padding //

  "custom/l_end": {
    "format": " ",
    "interval" : "once",
    "tooltip": false
  },

  "custom/r_end": {
    "format": " ",
    "interval" : "once",
    "tooltip": false
  },

  "custom/ll_end": {
    "format": " ",
    "interval" : "once",
    "tooltip": false
  },

  "custom/sr_end": {
    "format": " ",
    "interval" : "once",
    "tooltip": false
  },

  "custom/rl_end": {
    "format": " ",
    "interval" : "once",
    "tooltip": false
  },

  "custom/rr_end": {
    "format": " ",
    "interval" : "once",
    "tooltip": false
  }

}]
