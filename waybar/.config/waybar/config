{

    "layer": "top",
    "position": "top",
    "mod": "dock",
    "height": 45,
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,


	"modules-left": [
        "custom/ll_end",
        "hyprland/workspaces",
        "hyprland/window",
        "custom/r_end",
        "custom/l_end",
        "cpu",
        "memory",
        "temperature",
        "custom/r_end",
        "custom/l_end",
        "network",
        "custom/rr_end"
    ],

	"modules-center": [
        "custom/ll_end",
        "custom/spotify",
        "custom/rr_end"
    ],

	"modules-right": [
        "custom/ll_end",
        "clock",
        "custom/r_end",
        "custom/l_end",
        "battery",
        "pulseaudio",
        "pulseaudio#microphone",
        "custom/updates",
        "custom/r_end",
        "custom/l_end",
        "tray",
        "custom/rr_end"
    ],


    "cpu": {
        "interval": 10,
        "format": "у°Ќ›  {usage}%",
        "format-alt": "{icon0}{icon1}{icon2}{icon3}",
        "format-icons": ["в–Ѓ", "в–‚", "в–ѓ", "в–„", "в–…", "в–†", "в–‡", "в–€"]
    },

    "memory": {
        "interval": 30,
        "format": "у°ѕ†  {percentage}%",
        "format-alt": "у°ѕ…  {used}GB",
        "max-length": 30,
        "tooltip": true,
        "tooltip-format": "о‰¦  {used:0.1f}GB/{total:0.1f}GB"
    },

    "temperature": {
       "format": "п‹‰  {temperatureC}В°C"
    },

    "clock": {
        "format": "{:пђє   %I:%M %p у°ѓ­  %a %d}",
        "format-alt": "{:у°Ґ”   %H:%M п„і  %b %Y}",
        "tooltip-format": "<tt><big>{calendar}</big></tt>"
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate"
    },

    "hyprland/window": {
        "format": " пЊѓ {}",
        "max-length": 30,
        "separate-outputs": true,
        "rewrite": {
            "comodino@katalinux:(.*)": "$1 п’‰",
            "(.*) вЂ” Mozilla Firefox": "$1 у°€№",
            "(.*)Mozilla Firefox": "Firefox у°€№",
            "(.*) - Brave": "$1 у°Џљ",
            "(.*)Brave": "Brave у°Џљ",
            "(.*) вЂ” Dolphin": "$1 у°‰‹",
            "(.*)Spotify": "Spotify у°“‡",
            "(.*)Steam": "Steam у°““"
        }
    },

    "custom/spotify": {
        "format": "у°“‡  {}",
        "return-type": "json",
        "max-length": 30,
        "on-click": "playerctl play-pause -p spotify",
        "on-click-right": "playerctl next -p spotify",
        "on-click-middle": "playerctl previous -p spotify",
        "on-scroll-up": "playerctl volume 0.1+ -p spotify",
        "on-scroll-down": "playerctl volume 0.1- -p spotify",
        "exec": "spotifatius monitor"
    },

    "network": {
        "interface": "wlp5s0",
        "max-length": 30,
        "format-wifi": "{bandwidthUpBytes} оЄ· оЄґ {bandwidthDownBytes}",
        "tooltip": true,
        "tooltip-format": "{ifname}"
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 20
        },
        "format": "{icon} {capacity}%",
        "format-charging": "п‡¦ {capacity}%",
        "format-plugged": "п‡¦ {capacity}%",
