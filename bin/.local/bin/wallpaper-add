#!/usr/bin/env bash

[[ -z $1 ]] && echo "Usage: $0 <wallpaper>" && exit 1
[[ ! -f $1 ]] && echo "File not found: $1" && exit 1

file --mime-type -b $1 | grep -q image || echo "Not an image: $1" && exit 1

for dir in $(find ~/.config/swww/ -mindepth 1 -maxdepth 1 -type d; do
 
    [[ -f $dir/$(basename $1) ]] && echo "File already exists: $dir/$(basename $1)" && continue
    
    cp $1 $dir
done
