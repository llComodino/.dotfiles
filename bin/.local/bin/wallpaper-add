#!/bin/sh

# Script to copy the wallpaper (argument) to all the dirs in ~/.config/swww/cache
 
# Check if file exists
[[ -z $1 ]] && echo "No file specified" && exit 1
[[ ! -f $1 ]] && echo "File does not exist" && exit 1

# Check if file is an image
[[ ! $(file -b --mime-type $1) =~ ^image/ ]] && echo "File is not an image" && exit 1

# Copy the file to all the dirs in ~/.config/swww/cache
# There are also some files in the cache dir, we need to copy only to the dirs
for dir in ~/.config/swww/cache/*; do
    # If file is already in the dir, skip
    [[ -f $dir/$(basename $1) ]] && echo "File is already there" && continue

    # Copy the file to the dir
    cp $1 $dir
done
